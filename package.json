{
	"name": "@komunite/kalfa",
	"version": "1.0.0",
	"description": "Kalfa - Claude Code için Türkçe profesyonel işletim sistemi",
	"private": false,
	"license": "MIT",
	"author": "Komunite",
	"contributors": [
		{
			"name": "Doğu Abaris",
			"email": "abaris@null.net",
			"url": "https://doguabaris.bio"
		},
		{
			"name": "Fatih Guner"
		}
	],
	"bin": {
		"kalfa": "bin/kalfa.js"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/komunite/kalfa.git"
	},
	"bugs": {
		"url": "https://github.com/komunite/kalfa/issues"
	},
	"website": "https://www.komunite.com.tr",
	"homepage": "https://github.com/komunite/kalfa#readme",
	"keywords": [
		"claude-code",
		"automation",
		"workflow",
		"agents",
		"skills"
	],
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"cli": "node ./bin/kalfa.js",
		"cli:help": "node ./bin/kalfa.js --help",
		"pack:preview": "npm pack --dry-run",
		"test": "node --test tests/*.test.js",
		"test:watch": "node --test --watch tests/*.test.js",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"lint": "biome check . && npm run lint:md",
		"lint:fix": "biome check --fix .",
		"check": "biome check . && npm run lint:md",
		"lint:md": "remark . --frail --quiet",
		"lint:md:fix": "remark . --output --quiet"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"remark-cli": "^12.0.1",
		"remark-gfm": "^4.0.1",
		"remark-preset-lint-recommended": "^7.0.1"
	},
	"dependencies": {
		"figlet": "^1.11.0"
	}
}
